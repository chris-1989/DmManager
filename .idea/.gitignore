# ======================
# Java 项目常用忽略规则
# ======================

# IDE 配置文件（如 IDEA、Eclipse）
.idea/
*.iml
*.ipr
*.iws
workspace.xml
*.suo
*.user

# 构建输出目录（Maven/Gradle）
target/
build/
out/
bin/

# 编译后的字节码文件
*.class

# 密钥库文件（Java 密钥管理）
.keystore

# 依赖目录（如 Maven/Gradle 缓存）
.m2/
.gradle/
ivy/
.h2/

# 日志文件
*.log
logs/

# 临时文件
*~
*.tmp
*.temp
*.swp
*.swo

# Windows 动态链接库（.dll）
*.dll

# 项目特定目录（如 dm_dll）
dm_dll/
dm_dll/**

# 其他常见忽略
.DS_Store
Thumbs.db
desktop.ini
